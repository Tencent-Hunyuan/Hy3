# ============================================================
# Hy3（腾讯混元）—— 远程 API，OpenAI 兼容
# ============================================================

# base_url 必须是 base 形式（以 /v1 结尾），SDK 会自动补 /chat/completions
HY3_API_KEY=在此填入你的_Hy3_API_Key
HY3_BASE_URL=https://tokenhub.tencentmaas.com/v1
HY3_MODEL=hy3

# ------------------------------------------------------------
# 采样与推理参数
# reasoning_effort 仅对 Hy3 生效：no_think | low | high
# 复杂分析任务建议 high
# ------------------------------------------------------------
LLM_TEMPERATURE=0.9
LLM_TOP_P=1.0
LLM_REASONING_EFFORT=high
