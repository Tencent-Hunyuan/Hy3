# Hy3 OpenAI 兼容 API
# 复制为 .env 后按实际部署修改；不要在此文件中填写并提交真实密钥。

# API 根地址。OpenAI SDK 会在其后请求 /chat/completions。
HY3_BASE_URL=http://127.0.0.1:8000/v1

# 仓库的本地自部署示例使用 EMPTY；若服务启用了鉴权，请替换为实际 Key。
HY3_API_KEY=EMPTY

# 必须与服务启动参数 --served-model-name 的值一致。
HY3_MODEL=hy3

# quickstart.md 中使用的请求默认值。
HY3_TEMPERATURE=0.9
HY3_TOP_P=1.0
HY3_MAX_TOKENS=128

# 可选值：no_think、low、high。为避免模板默认值差异，建议显式设置。
HY3_REASONING_EFFORT=no_think

# 错误处理与重试示例的可选配置。
HY3_TIMEOUT_SECONDS=30
HY3_MAX_RETRIES=3
HY3_RETRY_BASE_SECONDS=1
HY3_RETRY_MAX_SECONDS=30
