# hyshell configuration — copy to .env and `export $(grep -v '^#' .env | xargs)`,
# or export the variables directly in your shell profile.
# 没有任何变量时 hyshell 也能跑:自动进入离线演示模式(内置确定性伪 Hy3 后端)。

# --- Hy3 backend (choose ONE base URL style) --------------------------------
# 1) Tencent Cloud Hunyuan OpenAI-compatible endpoint (以腾讯云控制台文档为准):
#HY3_API_BASE=https://api.hunyuan.cloud.tencent.com/v1
# 2) Self-hosted vLLM / SGLang (Hy3 repo README default):
#HY3_API_BASE=http://127.0.0.1:8000/v1

# Your API key. NEVER commit a real key. Leaving it unset = offline demo mode.
#HY3_API_KEY=

# Model name served by the endpoint (vLLM: --served-model-name hy3)
#HY3_MODEL=hy3

# --- Sampling (defaults follow the Hy3 repo README recommendations) ---------
#HY3_TEMPERATURE=0.9
#HY3_TOP_P=1.0

# Optional: only sent when set (extra_body.chat_template_kwargs.reasoning_effort)
# Accepted by self-hosted vLLM/SGLang chat templates: no_think | low | high
#HY3_REASONING_EFFORT=low

# --- hyshell behaviour -------------------------------------------------------
#HY3_TIMEOUT=60
#HYSHELL_MAX_FIX_RETRIES=2
# Force offline demo mode even if HY3_API_KEY is set:
#HYSHELL_OFFLINE=1
# Where session history (history.jsonl) lives; default ~/.hyshell
#HYSHELL_HOME=~/.hyshell
