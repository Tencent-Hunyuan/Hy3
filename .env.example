# Hy3 API Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Self-hosted (vLLM / SGLang) ──────────────────────
HY3_BASE_URL=http://127.0.0.1:8000/v1
HY3_API_KEY=EMPTY
HY3_MODEL=hy3

# ── Tencent Cloud Hunyuan ────────────────────────────
# HY3_BASE_URL=https://tokenhub.tencentmaas.com/v1
# HY3_API_KEY=your-tencent-cloud-api-key
# HY3_MODEL=hy3

# ── OpenRouter ───────────────────────────────────────
# HY3_BASE_URL=https://openrouter.ai/api/v1
# HY3_API_KEY=your-openrouter-api-key
# HY3_MODEL=tencent/hy3

# ── Custom Gateway ───────────────────────────────────
# HY3_BASE_URL=https://your-gateway.com/v1
# HY3_API_KEY=your-gateway-api-key
# HY3_MODEL=hy3
