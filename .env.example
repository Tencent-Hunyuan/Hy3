# 选择调用后端：hy3 使用本地部署，hunyuan 使用腾讯混元 OpenAI-compatible API。
API_PROVIDER=hy3

# 本地 Hy3（README 中的默认配置）
HY3_BASE_URL=http://127.0.0.1:8000/v1
HY3_API_KEY=EMPTY
HY3_MODEL=hy3

# 腾讯混元 OpenAI-compatible API
# API key 请在腾讯云混元控制台创建，不要提交真实密钥。
HUNYUAN_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
HUNYUAN_API_KEY=your-hunyuan-api-key-here
HUNYUAN_MODEL=hunyuan-turbos-latest

# OpenAI SDK 请求超时（秒）
OPENAI_TIMEOUT_SECONDS=60

# 06_error_handling_retry.py 使用的重试参数
MAX_RETRIES=4
RETRY_BASE_DELAY_SECONDS=1
RETRY_MAX_DELAY_SECONDS=8
