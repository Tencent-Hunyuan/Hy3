# Hy3 API 示例环境变量（默认本地部署）
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env

# —— 本地部署（默认，需先在本地启动 vLLM / SGLang）——
HY3_API_KEY=EMPTY
HY3_BASE_URL=http://127.0.0.1:8000/v1
HY3_MODEL=hy3

# —— 云端 TokenHub——
# HY3_API_KEY=你的密钥
# HY3_BASE_URL=https://tokenhub.tencentmaas.com/v1
# HY3_MODEL=hy3

# 请求超时（秒）
HY3_TIMEOUT_SECONDS=60

# 思考模式单次最大输出 token（示例 05 使用）
HY3_REASONING_MAX_TOKENS=4096



