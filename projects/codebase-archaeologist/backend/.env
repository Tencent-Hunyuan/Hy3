# Hy3 API Configuration
# Get your API key from https://tokenhub.tencentmaas.com
ARCHAEOLOGIST_HY3_API_KEY=
ARCHAEOLOGIST_HY3_BASE_URL=https://tokenhub.tencentmaas.com/v1
ARCHAEOLOGIST_HY3_MODEL=hy3

# Optional: Web search (for MCP web_search tool)
ARCHAEOLOGIST_TAVILY_API_KEY=

# Server
ARCHAEOLOGIST_HOST=0.0.0.0
ARCHAEOLOGIST_PORT=8000

# Analysis tuning (adjust based on your API tier)
# ARCHAEOLOGIST_MAX_CONTEXT_TOKENS=240000
# ARCHAEOLOGIST_MAX_REACT_ROUNDS_PER_BATCH=10
