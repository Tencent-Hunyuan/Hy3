# Hy3 API
HY3_API_KEY=replace_me
HY3_BASE_URL=https://api.example.com/v1
HY3_MODEL=hy3

# 推理强度：high（复杂任务）/ no_think（简单修复）。
# API 不支持推理扩展参数时，可将 HY3_ENABLE_REASONING_PARAM 设为 false。
HY3_REASONING_EFFORT=high
HY3_ENABLE_REASONING_PARAM=true
# 推理参数格式：chat_template_kwargs 或 direct。
HY3_REASONING_PARAM_STYLE=chat_template_kwargs

# JSON Schema 结构化输出。
HY3_ENABLE_RESPONSE_FORMAT=true

# 网络与重试
HY3_TIMEOUT_SECONDS=120
HY3_MAX_RETRIES=2

# 文档限制
RULELENS_MAX_FILE_MB=10
RULELENS_MAX_CHARS=100000
