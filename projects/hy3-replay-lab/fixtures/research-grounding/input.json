    },
    {
      "evidence_id": "ev-source-b",
      "step_id": "step-005-read-source-b",
      "kind": "source_excerpt",
      "source_label": "合成来源 B",
      "content": "各团队每月提交实施检查表。该记录没有报告结果比较，也没有提出因果主张。"
    },
    {
      "evidence_id": "ev-unsupported-draft",
      "step_id": "step-007-wrong-citation",
      "kind": "artifact",
      "source_label": "合成草稿摘录",
      "content": "政策带来了改善，月度检查表报告证明了这一点［来源 B］。"
    }
  ]
}
