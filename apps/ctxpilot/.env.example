# Hy3 接入配置（复制为 .env 后填写，.env 已被 .gitignore 忽略）
# 腾讯云 / AI Studio 云端（已验证可用，推荐）：
HY3_BASE_URL=https://tokenhub.tencentmaas.com/v1
# 本地 vLLM / SGLang 部署示例：
# HY3_BASE_URL=http://127.0.0.1:8000/v1
HY3_API_KEY=your-hy3-api-key-here
HY3_MODEL=hy3
# 推理强度：no_think(默认) / low / high（复杂任务用 high）
HY3_REASONING_EFFORT=low
