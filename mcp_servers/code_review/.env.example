# Copy to .env and fill in your values. NEVER commit the real .env.
#
# --- Backend endpoint (OpenAI-compatible) ---
# Option 1: OpenRouter (no GPU required)
HY3_BASE_URL=https://openrouter.ai/api/v1
HY3_API_KEY=<your-openrouter-api-key>
HY3_MODEL=tencent/hy3:free

# Option 2: Local Hy3 via vLLM / SGLang
# HY3_BASE_URL=http://127.0.0.1:8000/v1
# HY3_API_KEY=EMPTY
# HY3_MODEL=hy3

# --- Optional: restrict which directories analyze_file may read ---
# Colon-separated (POSIX) list of allowed roots. Unset = no restriction.
# HY3_ALLOWED_ROOTS=/home/user/projects
