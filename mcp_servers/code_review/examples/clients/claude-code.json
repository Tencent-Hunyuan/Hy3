{
  "mcpServers": {
    "hy3-code-review": {
      "type": "stdio",
      "command": "uvx",
      "args": ["hy3-code-review-mcp"],
      "env": {
        "HY3_BASE_URL": "https://openrouter.ai/api/v1",
        "HY3_API_KEY": "<your-openrouter-api-key>",
        "HY3_MODEL": "tencent/hy3:free"
      }
    }
  }
}
