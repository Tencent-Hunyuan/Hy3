HY3_API_KEY=replace-with-your-local-secret
HY3_BASE_URL=https://openrouter.ai/api/v1
HY3_MODEL=tencent/hy3:free
HY3_ENDPOINT_PROFILE=openrouter
HY3_REASONING_EFFORT=high
HY3_TIMEOUT_SECONDS=60
HY3_MAX_RETRIES=2
HY3_MAX_OUTPUT_TOKENS=2048

HY3_KB_ROOTS=C:\path\to\knowledge-base
HY3_KB_STORAGE_DIR=
HY3_KB_MAX_FILE_BYTES=10485760
HY3_KB_MAX_FILES_PER_RUN=500
HY3_KB_MAX_TOTAL_BYTES_PER_RUN=104857600
HY3_KB_MAX_DISCOVERY_ENTRIES=20000
HY3_KB_MAX_DISCOVERY_DIRECTORIES=2000
HY3_KB_MAX_DISCOVERY_DEPTH=64
HY3_KB_MAX_PDF_PAGES=500
HY3_KB_CHUNK_CHARS=3000
HY3_KB_CHUNK_OVERLAP_CHARS=300
HY3_KB_MAX_CONTEXT_CHARS=90000
HY3_KB_PROMPT_RESERVE_CHARS=8000
HY3_KB_MAX_SUMMARY_REQUESTS=16
