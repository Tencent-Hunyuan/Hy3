{
  "mcpServers": {
    "hy3-knowledge": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "${HY3_MCP_SOURCE}",
        "hy3-knowledge-mcp"
      ],
      "env": {
        "HY3_API_KEY": "${HY3_API_KEY}",
        "HY3_BASE_URL": "${HY3_BASE_URL}",
        "HY3_MODEL": "${HY3_MODEL}",
        "HY3_ENDPOINT_PROFILE": "${HY3_ENDPOINT_PROFILE}",
        "HY3_REASONING_EFFORT": "${HY3_REASONING_EFFORT}",
        "HY3_KB_ROOTS": "${HY3_KB_ROOTS}"
      }
    }
  }
}
