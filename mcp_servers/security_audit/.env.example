# API 密钥绝不硬编码,只从环境变量读取。/ API keys are NEVER hardcoded — read from environment variables only.
# 复制本文件为 .env 并取消注释你选择的后端。/ Copy this file to .env and uncomment ONE backend option below.

# ── Option 1 (default/recommended): OpenRouter ──────────────────────────────
#HY3_BASE_URL=https://openrouter.ai/api/v1
#HY3_API_KEY=sk-or-...
#HY3_MODEL=tencent/hy3:free

# ── Option 2: Tencent Cloud Hunyuan (OpenAI-compatible) ─────────────────────
#HY3_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
#HY3_API_KEY=...
#HY3_MODEL=hy3

# ── Option 3: local vLLM / SGLang ────────────────────────────────────────────
#HY3_BASE_URL=http://127.0.0.1:8000/v1
#HY3_API_KEY=EMPTY
#HY3_MODEL=hy3

# ── Generation options (defaults shown; uncomment to override) ──────────────
#HY3_TEMPERATURE=0.2
# Hy3 是推理模型,部分端点不遵循 reasoning_effort=no_think,需要充裕的 token 预算,
# 否则会把预算耗尽在隐藏推理上而返回空内容。/ Hy3 is a reasoning model — some
# endpoints don't honor reasoning_effort=no_think, so it needs a generous budget
# or it burns it all on hidden reasoning and returns empty content.
#HY3_MAX_TOKENS=8192
#HY3_TIMEOUT_SECONDS=120
