[116.686, "o", "{\r\n  \"secrets\": [\r\n    {\r\n      \"line\": 1,\r\n      \"kind\": \"AWS_ACCESS_KEY\",\r\n      \"is_true_positive\": true,\r\n      \"severity\": \"high\",\r\n      \"rationale\": \"扫描器在line 1匹配到aws_key赋值模式，符合AWS访问密钥特征，脱敏前应为真实密钥格式，判定为真阳性。\",\r\n      \"remediation\": \"立即轮换该AWS密钥，撤销暴露凭据，移入密管服务，并检查滥用。\"\r\n    },\r\n    {\r\n      \"line\": 2,\r\n      \"kind\": \"GENERIC_SECRET\",\r\n      \"is_true_positive\": true,\r\n      \"severity\": \"medium\",\r\n      \"rationale\": \"line 2被识别为通用秘密，同一行上下文含OpenAI密钥，推测为额外敏感凭据或密码，非高熵误报，判定为真阳性。\",\r\n      \"remediation\": \"将该通用秘密移入密管服务，审查其权限与用途，避免明文存储。\"\r\n    },\r\n    {\r\n      \"line\": 2,\r\n      \"kind\": \"OPENAI_KEY\",\r\n      \"is_true_positive\": true,\r\n      \"severity\": \"high\",\r\n      \"rationale\": \"line 2匹配到OpenAI API密钥特征，脱敏前符合令牌"]
[0.000, "o", "格式，具备实际调用权限，真阳性。\",\r\n      \"remediation\": \"在OpenAI账户轮换该API密钥，限制权限范围，并审计调用日志。\"\r\n    }\r\n  ],\r\n  \"summary\": \"本次分诊判定3个候选均为真实凭据泄露，涉及AWS密钥、OpenAI令牌及通用秘密，需紧急轮换并加强密钥管理。\"\r\n}"]
