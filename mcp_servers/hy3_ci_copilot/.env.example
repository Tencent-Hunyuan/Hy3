# Self-hosted Hy3 (vLLM/SGLang)
HY3_API_KEY=EMPTY
HY3_BASE_URL=http://127.0.0.1:8000/v1
HY3_MODEL=hy3

# For OpenRouter, use these values instead:
# HY3_API_KEY=your_openrouter_api_key
# HY3_BASE_URL=https://openrouter.ai/api/v1
# HY3_MODEL=tencent/hy3

# Optional runtime controls
HY3_API_STYLE=auto
HY3_ALLOWED_ROOTS=/absolute/path/to/your/repository
HY3_TIMEOUT_SECONDS=120
HY3_MAX_INPUT_CHARS=120000
HY3_MAX_OUTPUT_TOKENS=4096
HY3_MAX_RETRIES=2
