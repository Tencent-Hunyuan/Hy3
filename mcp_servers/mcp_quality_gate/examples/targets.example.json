{
  "version": 1,
  "allowed_roots": [
    "."
  ],
  "defaults": {
    "startup_timeout_ms": 5000,
    "request_timeout_ms": 10000,
    "total_timeout_ms": 30000,
    "max_stdout_bytes": 1048576,
    "max_stderr_bytes": 262144,
    "inherit_env": [
      "PATH"
    ]
  },
  "targets": {
    "fixture-good": {
      "description": "Synthetic conforming MCP server used for local quality-gate tests.",
      "command": "node",
      "args": [
        "fixtures/good-server/dist/index.js"
      ],
      "cwd": ".",
      "env": {
        "NODE_ENV": "test"
      }
    },
    "fixture-breaking-v2": {
      "description": "Synthetic second contract version used for compatibility tests.",
      "command": "node",
      "args": [
        "fixtures/breaking-change/v2/dist/index.js"
      ],
      "cwd": ".",
      "env": {
        "NODE_ENV": "test"
      },
      "limits": {
        "request_timeout_ms": 3000,
        "max_stderr_bytes": 131072
      }
    }
  }
}
