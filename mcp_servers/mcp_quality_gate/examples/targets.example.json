{
  "version": 1,
  "allowed_roots": [
    ".."
  ],
  "defaults": {
    "startup_timeout_ms": 5000,
    "request_timeout_ms": 10000,
    "total_timeout_ms": 30000,
    "max_stdout_bytes": 1048576,
    "max_stderr_bytes": 262144,
    "inherit_env": [
      "PATH"
    ]
  },
  "targets": {
    "fixture-good": {
      "description": "Synthetic conforming MCP server used for local quality-gate tests.",
      "command": "node",
      "args": [
        "dist/fixtures/good-server/index.js"
      ],
      "cwd": "..",
      "env": {
        "NODE_ENV": "test"
      }
    },
    "fixture-stdout-pollution": {
      "description": "Synthetic invalid MCP server that writes a startup banner to stdout.",
      "command": "node",
      "args": [
        "dist/fixtures/stdout-pollution/index.js"
      ],
      "cwd": "..",
      "env": {
        "NODE_ENV": "test"
      },
      "limits": {
        "request_timeout_ms": 3000,
        "max_stderr_bytes": 131072
      }
    },
    "fixture-audit-bad": {
      "description": "Synthetic MCP server containing deterministic contract defects.",
      "command": "node",
      "args": [
        "dist/fixtures/audit-bad-server/index.js"
      ],
      "cwd": "..",
      "env": {
        "NODE_ENV": "test"
      }
    }
  }
}
