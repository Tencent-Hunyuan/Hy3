# Stage 5 semantic audit. Never commit a real provider credential.
# EMPTY is suitable only for a local endpoint that does not authenticate.
HY3_API_KEY=
HY3_BASE_URL=http://127.0.0.1:8000/v1
HY3_MODEL=hy3
HY3_REASONING_EFFORT=high
HY3_TIMEOUT_MS=60000

# Absolute path to a private target registry. If omitted, the registry is empty.
MCPQ_TARGETS_FILE=
