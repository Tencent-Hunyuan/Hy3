{
  "mcpServers": {
    "hy3-taskrelay": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "mcp_servers/hy3_taskrelay",
        "hy3-taskrelay-mcp"
      ],
      "env": {
        "HY3_API_KEY": "${env:HY3_API_KEY}",
        "HY3_BASE_URL": "${env:HY3_BASE_URL}",
        "HY3_MODEL": "${env:HY3_MODEL}"
      }
    }
  }
}
