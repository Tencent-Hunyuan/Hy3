   "source": [
    "# Example 2: Streaming —— 流式请求\n",
    "\n",
    "演示 streaming 模式（`stream=True`），逐 token 接收 response。\n",
    "\n",
    "**前置条件：**\n",
    "1. 在 [TokenHub 控制台](https://console.cloud.tencent.com/tokenhub/apikey) 创建 API Key\n",
    "2. 安装 openai: `pip install openai`"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import time\n",
    "from openai import OpenAI\n",
    "\n",
    "API_KEY = \"sk-你的APIKey\"  # TODO: 替换\n",
    "\n",
    "client = OpenAI(\n",
    "    base_url=\"https://tokenhub.tencentmaas.com/v1\",\n",
    "    api_key=API_KEY,\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Streaming 请求"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "prompt = \"请写一段关于人工智能未来发展的短文，大约200字左右。\"\n",
    "print(f\"User: {prompt}\")\n",
    "\n",
    "start_time = time.time()\n",
    "first_token_time = None\n",
    "\n",
    "response = client.chat.completions.create(\n",
    "    model=\"hy3\",\n",
    "    messages=[{\"role\": \"user\", \"content\": prompt}],\n",
    "    temperature=0.9, top_p=1.0,\n",
    "    stream=True,\n",
    "    extra_body={\"reasoning_effort\": \"no_think\"},\n",
    ")\n",
    "\n",
    "full_content = \"\"\n",
    "print(\"\\nAssistant: \", end=\"\", flush=True)\n",
    "for chunk in response:\n",
    "    if first_token_time is None:\n",
    "        first_token_time = time.time()\n",
    "        print(f\"\\n--- TTFT: {first_token_time - start_time:.2f}s ---\\n\")\n",
    "\n",
    "    delta = chunk.choices[0].delta\n",
    "    content = delta.content or \"\"\n",
    "    if content:\n",
    "        full_content += content\n",
    "        print(content, end=\"\", flush=True)\n",
    "\n",
    "    if chunk.choices[0].finish_reason:\n",
    "        end_time = time.time()\n",
    "        finish_reason = chunk.choices[0].finish_reason\n",
    "\n",
    "print()\n",
    "print(f\"\\n--- Streaming 统计 ---\")\n",
    "print(f\"TTFT:        {first_token_time - start_time:.2f}s\")\n",
    "print(f\"总耗时:       {end_time - start_time:.2f}s\")\n",
    "print(f\"生成字符:     ~{len(full_content)}\")\n",
    "print(f\"finish_reason: {finish_reason}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Streaming chunk 结构\n",
    "\n",
    "每个 chunk 包含 `delta`（增量内容）而非完整消息。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"--- chunk 结构示例（前 4 个） ---\\n\")\n",
    "\n",
    "response = client.chat.completions.create(\n",
    "    model=\"hy3\",\n",
    "    messages=[{\"role\": \"user\", \"content\": \"用三个词回答：今天天气怎么样？\"}],\n",
    "    temperature=0.7, top_p=1.0,\n",
    "    stream=True,\n",
    "    extra_body={\"reasoning_effort\": \"no_think\"},\n",
    ")\n",
    "\n",
    "for i, chunk in enumerate(response):\n",
    "    if i >= 4:\n",
    "        break\n",
    "    d = chunk.choices[0].delta\n",
    "    print(f\"Chunk {i}:\")\n",
    "    print(f\"  id:       {chunk.id}\")\n",
    "    print(f\"  delta:    role={d.role}, content={repr(d.content)}\")\n",
    "    print(f"  finish:   {chunk.choices[0].finish_reason}\\n\")"
   ]
  }
 ],
