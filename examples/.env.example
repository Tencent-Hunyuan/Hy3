# Copy to .env and fill in values (never commit real keys).
# Examples read these via environment variables.

# --- Local vLLM / SGLang (default) ---
HY3_BASE_URL=http://127.0.0.1:8000/v1
HY3_API_KEY=EMPTY
HY3_MODEL=hy3
HY3_TIMEOUT=120

# --- Tencent Cloud TokenHub (hosted, no local GPU needed) ---
# HY3_BASE_URL=https://tokenhub.tencentmaas.com/v1
# HY3_API_KEY=sk-xxxxxxxx
# HY3_MODEL=hy3
