# Remote OpenAI-compatible Hy3 endpoint. OpenRouter is the default provider.
HY3_BASE_URL=https://openrouter.ai/api/v1
HY3_API_KEY=replace-with-your-api-key
HY3_MODEL=tencent/hy3:free

# Optional runtime controls.
HY3_REASONING_EFFORT=high
HY3_MAX_ROUNDS=9
HY3_MAX_TOOL_CALLS=32
HY3_MAX_CONTEXT_CHARS=120000
HY3_MAX_TOOL_RESULT_CHARS=24000
HY3_MAX_TOKENS=16384
HY3_TIMEOUT=90
