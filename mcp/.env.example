# ============================================================
# Hy3 Deep Research MCP Server - environment variables
# Copy this file to `.env` and fill in your values.
# NEVER commit the real .env file. All keys come from env vars.
# ============================================================

# [REQUIRED] TokenHub API key (sk-...) from Tencent Cloud TokenHub.
# Get one at: https://console.cloud.tencent.com/tokenhub
HUNYUAN_API_KEY=your-tokenhub-api-key-here

# [OPTIONAL] Hy3 API endpoint (OpenAI-compatible). Default: TokenHub.
# TokenHub (Guangzhou): https://tokenhub.tencentmaas.com/v1
# TokenHub (Singapore):  https://tokenhub-intl.tencentmaas.com/v1
# Old Hunyuan endpoint (deprecated): https://api.hunyuan.cloud.tencent.com/v1
HUNYUAN_BASE_URL=https://tokenhub.tencentmaas.com/v1

# [OPTIONAL] Model name. Default: hy3
HUNYUAN_MODEL=hy3

# [OPTIONAL] How reasoning_effort is passed to the API.
#   "top"      -> extra_body={"reasoning_effort": ...}                            (TokenHub cloud, default)
#   "template" -> extra_body={"chat_template_kwargs": {"reasoning_effort": ...}}  (self-deployed vLLM/SGLang)
HUNYUAN_REASONING_FORMAT=top

# [OPTIONAL] Tavily search API key. If unset, DuckDuckGo (no key) is used.
# TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] Search behavior
SEARCH_MAX_RESULTS=5

# [OPTIONAL] Web page fetch behavior
FETCH_MAX_CHARS=8000
FETCH_TIMEOUT=30

# [OPTIONAL] Deep research orchestration
RESEARCH_MAX_SUB_QUERIES=3
RESEARCH_MAX_SOURCES=3
RESEARCH_REASONING_EFFORT=high

# [OPTIONAL] Logging level for stderr output. Default: INFO
#   DEBUG / INFO / WARNING / ERROR
HY3_LOG_LEVEL=INFO
